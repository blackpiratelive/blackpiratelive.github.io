.blog-page .prose blockquote {
    border-left: 4px solid #f43f5e;
    background-color: rgba(39, 39, 42, 0.5);
    padding: 1.5rem;
    border-radius: 0 1rem 1rem 0;
  }
.blog-page .prose ul {
    list-style: disc;
    padding-left: 1.5rem;
  }
.blog-page .prose li {
    margin-bottom: 0.5rem;
  }
