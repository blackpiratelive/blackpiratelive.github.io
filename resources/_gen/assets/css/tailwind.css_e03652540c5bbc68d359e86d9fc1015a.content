.blog-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
    padding: 1rem;
    max-width: 1400px;
    margin: 0 auto;
    align-items: start;
  }
.blog-card {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }
.blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
    z-index: 10;
  }
@media (max-width: 1023px) {
    .blog-left-column,
    .blog-right-column {
      display: contents;
    }

    .blog-box-nav {
      order: 1;
    }

    .blog-box-hero {
      order: 2;
    }

    .blog-box-meta {
      order: 3;
    }

    .blog-box-article {
      order: 4;
    }

    .blog-box-toc {
      order: 5;
    }

    .blog-box-next {
      order: 6;
    }

    .blog-box-ad {
      order: 7;
    }

    .blog-box-footer {
      order: 8;
    }
  }
@media (min-width: 768px) and (max-width: 1023px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .blog-box-nav,
    .blog-box-hero,
    .blog-box-meta,
    .blog-box-article,
    .blog-box-ad,
    .blog-box-footer,
    .blog-box-list {
      grid-column: 1 / 3;
    }

    .blog-box-toc {
      grid-column: 1 / 2;
    }

    .blog-box-next {
      grid-column: 2 / 3;
    }
  }
@media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: 220px 1fr 240px;
      gap: 1.5rem;
    }

    .blog-left-column,
    .blog-right-column {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .blog-box-hero {
      grid-column: 1 / 4;
      height: 380px;
    }

    .blog-left-column {
      grid-column: 1 / 2;
      position: sticky;
      top: 1.5rem;
      max-height: calc(100vh - 3rem);
      overflow-y: auto;
    }

    .blog-box-article,
    .blog-box-list {
      grid-column: 2 / 3;
    }

    .blog-right-column {
      grid-column: 3 / 4;
      position: sticky;
      top: 1.5rem;
      max-height: calc(100vh - 3rem);
      overflow-y: auto;
    }

    .blog-box-footer {
      grid-column: 1 / 4;
    }
  }
.mosaic-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
    grid-auto-rows: minmax(240px, auto);
    padding: 1rem;
    max-width: 1400px;
    margin: 0 auto;
  }
.mosaic-box {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }
body.mosaic-home .mosaic-box:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
    z-index: 10;
  }
@media (min-width: 768px) {
    .mosaic-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }

    .box-hero {
      grid-column: span 2;
      grid-row: span 2;
    }

    .box-nav {
      grid-column: span 1;
      grid-row: span 1;
    }

    .box-about {
      grid-column: span 1;
      grid-row: span 1;
    }

    .box-posts {
      grid-column: span 2;
      grid-row: span 1;
    }

    .box-pics {
      grid-column: span 2;
      grid-row: span 1;
    }

    .box-books {
      grid-column: span 2;
      grid-row: span 1;
    }

    .box-interests {
      grid-column: span 1;
      grid-row: span 1;
    }

    .box-thoughts {
      grid-column: span 1;
      grid-row: span 1;
    }

    .box-webring {
      grid-column: span 1;
      grid-row: span 1;
    }

    .box-buttons {
      grid-column: span 1;
      grid-row: span 1;
    }

    .box-footer {
      grid-column: span 2;
      grid-row: span 1;
    }
  }
@media (min-width: 1024px) {
    .mosaic-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
      grid-auto-rows: 280px;
    }

    .box-nav {
      grid-column: span 1;
      grid-row: span 2;
    }

    .box-hero {
      grid-column: span 2;
      grid-row: span 2;
    }

    .box-about {
      grid-column: span 1;
      grid-row: span 2;
    }

    .box-posts {
      grid-column: span 1;
      grid-row: span 2;
    }

    .box-pics {
      grid-column: span 2;
      grid-row: span 1;
    }

    .box-interests {
      grid-column: span 1;
      grid-row: span 1;
    }

    .box-books {
      grid-column: span 2;
      grid-row: span 1;
    }

    .box-thoughts {
      grid-column: span 1;
      grid-row: span 1;
    }

    .box-webring {
      grid-column: span 2;
      grid-row: span 1;
    }

    .box-buttons {
      grid-column: span 2;
      grid-row: span 1;
    }

    .box-footer {
      grid-column: span 4;
      grid-row: span 1;
    }
  }
.blog-page .prose {
    color: #e4e4e7;
  }
.blog-page .prose a {
    color: #f8fafc;
    text-decoration: underline;
